{
  "name": "hell-strait",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "generate:art": "node scripts/stability-generate.mjs",
    "generate:carrier": "node scripts/stability-generate.mjs -- --preset=carrier --name=carrier-cinemaware --aspect=16:9",
    "generate:missile-inbound": "node scripts/stability-generate.mjs -- --preset=missile-inbound --name=missile-inbound --aspect=9:16",
    "generate:missile-interceptor": "node scripts/stability-generate.mjs -- --preset=missile-interceptor --name=missile-interceptor --aspect=9:16",
    "generate:gulf-assets": "npm run generate:carrier && npm run generate:missile-inbound && npm run generate:missile-interceptor"
  },
  "dependencies": {
    "phaser": "^3.90.0",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@types/three": "^0.172.0",
    "dotenv": "^17.4.1",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  }
}
