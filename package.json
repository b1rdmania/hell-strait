{
  "name": "hell-strait",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "generate:art": "node scripts/stability-generate.mjs",
    "generate:carrier": "node scripts/stability-generate.mjs -- --preset=carrier --name=carrier-cinemaware --aspect=16:9",
    "generate:gulf-bg": "node scripts/stability-generate.mjs -- --preset=gulf-bg --name=gulf-bg --aspect=16:9",
    "generate:gulf-assets": "npm run generate:gulf-bg && npm run generate:carrier"
  },
  "dependencies": {
    "phaser": "^3.90.0",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@types/three": "^0.172.0",
    "dotenv": "^17.4.1",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  }
}
