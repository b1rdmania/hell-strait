{
  "name": "hell-strait",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "generate:art": "node scripts/stability-generate.mjs",

    "generate:title-art":       "node scripts/stability-generate.mjs -- --out=images/title-art.png      --aspect=16:9",
    "generate:scene-border":    "node scripts/stability-generate.mjs -- --out=images/scene-border.png   --aspect=16:9",
    "generate:scene-hamid":     "node scripts/stability-generate.mjs -- --out=images/scene-hamid.png    --aspect=16:9",
    "generate:scene-boat":      "node scripts/stability-generate.mjs -- --out=images/scene-boat.png     --aspect=16:9",
    "generate:win-art":         "node scripts/stability-generate.mjs -- --out=images/win-art.png        --aspect=16:9",
    "generate:lose-art":        "node scripts/stability-generate.mjs -- --out=images/lose-art.png       --aspect=16:9",
    "generate:sprite-player":   "node scripts/stability-generate.mjs -- --out=images/sprite-player.png  --aspect=1:1",
    "generate:sprite-drone":    "node scripts/stability-generate.mjs -- --out=images/sprite-drone.png   --aspect=1:1",
    "generate:sprite-boat":     "node scripts/stability-generate.mjs -- --out=images/sprite-boat.png    --aspect=1:1",
    "generate:sprite-zyn":      "node scripts/stability-generate.mjs -- --out=images/sprite-zyn.png     --aspect=1:1",
    "generate:sprite-cigar":    "node scripts/stability-generate.mjs -- --out=images/sprite-cigar.png   --aspect=1:1",
    "generate:sprite-coastguard":"node scripts/stability-generate.mjs -- --out=images/sprite-coastguard.png --aspect=1:1",
    "generate:screens":         "npm run generate:title-art && npm run generate:scene-border && npm run generate:scene-hamid && npm run generate:scene-boat && npm run generate:win-art && npm run generate:lose-art",
    "generate:sprites":         "npm run generate:sprite-player && npm run generate:sprite-drone && npm run generate:sprite-boat && npm run generate:sprite-zyn && npm run generate:sprite-cigar && npm run generate:sprite-coastguard",
    "generate:all":             "npm run generate:screens && npm run generate:sprites",

    "generate:bg-strait":        "node scripts/stability-generate.mjs -- --name=bg-strait --aspect=16:9",
    "generate:command-deck":     "node scripts/stability-generate.mjs -- --name=command-deck --aspect=16:9",
    "generate:carrier":          "node scripts/stability-generate.mjs -- --preset=carrier --name=carrier-cinemaware --aspect=16:9",
    "generate:gulf-bg":          "node scripts/stability-generate.mjs -- --preset=gulf-bg --name=gulf-bg --aspect=16:9",
    "generate:missile-inbound":  "node scripts/stability-generate.mjs -- --preset=missile-inbound --name=missile-inbound --aspect=9:16",
    "generate:missile-interceptor": "node scripts/stability-generate.mjs -- --preset=missile-interceptor --name=missile-interceptor --aspect=9:16",
    "generate:gulf-assets":      "npm run generate:gulf-bg && npm run generate:carrier",
    "generate:all-stability":    "npm run generate:bg-strait && npm run generate:command-deck && npm run generate:gulf-bg && npm run generate:carrier && npm run generate:missile-inbound && npm run generate:missile-interceptor"
  },
  "dependencies": {
    "phaser": "^3.90.0",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@types/three": "^0.172.0",
    "dotenv": "^17.4.1",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  }
}
